rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
          'firstName',
          'lastName',
          'primaryStationName',
          'additionalStationNames',
          'onboardingCompleted',
          'onboardingSkippedAt',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.primaryStationName is string
        && request.resource.data.additionalStationNames is list
        && request.resource.data.onboardingCompleted is bool
        && (request.resource.data.onboardingSkippedAt == null
          || request.resource.data.onboardingSkippedAt is string)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.primaryStationName is string
        && request.resource.data.additionalStationNames is list
        && request.resource.data.onboardingCompleted is bool
        && (request.resource.data.onboardingSkippedAt == null
          || request.resource.data.onboardingSkippedAt is string)
        && request.resource.data.updatedAt is string;
    }
  }
}
